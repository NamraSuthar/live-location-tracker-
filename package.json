{
  "name": "live-location-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Real-time location tracking application with client and server",
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "dev": "pnpm -r dev",
    "setup": "pnpm install"
  },
  "workspaces": [
    "server",
    "client"
  ]
}
